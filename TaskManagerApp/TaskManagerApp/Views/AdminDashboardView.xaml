<Window x:Class="TaskManagerApp.Views.AdminDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:TaskManagerApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManagerApp.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:AdminViewModel}"
        Title="Admin Task Management" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F4F4F9">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <!-- Define Columns: [Navigation/Filter] [Task List] [Details] [Leaderboard] -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Left Sidebar -->
            <ColumnDefinition Width="300"/>
            <!-- Task List -->
            <ColumnDefinition Width="*"/>
            <!-- Details Pane -->
            <ColumnDefinition Width="200"/>
            <!-- Leaderboard -->
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT SIDEBAR: Navigation & Filters -->
        <Border Grid.Column="0" Background="#2C3E50" Padding="15">
            <StackPanel>
                <TextBlock Name="Title" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Filter Tasks:" Foreground="#BDC3C7" Margin="0,10,0,5"/>
                <ComboBox x:Name="StatusFilter" 
                          SelectedValue="{Binding SelectedFilter}"
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="All"/>
                    <ComboBoxItem Content="Pending"/>
                    <ComboBoxItem Content="Active"/>
                    <ComboBoxItem Content="Completed"/>
                    <ComboBoxItem Content="Rejected"/>
                </ComboBox>

                <Separator Margin="0,20" Background="#34495E"/>

                <Button Content="Create Users" Click="OpenCreateUser_Click" Margin="0,5" Height="30" Cursor="Hand"/>
                <Button Content="Create Task" Click="OpenCreateTask_Click" Margin="0,5" Height="30" Cursor="Hand"/>
                <Button Content="Logout" Click="Logout_Click" Margin="0,50,0,0" Background="#E74C3C" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- 2. TASK LIST (The "Master" part) -->
        <Grid Grid.Column="1" Background="White">
            <ListView ItemsSource="{Binding VisibleTasks}" 
                      SelectedItem="{Binding SelectedTask}"
                      BorderThickness="0" Margin="5">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding Username}" Foreground="Gray"/>
                            <TextBlock Text="{Binding Status}" FontSize="10" FontStyle="Italic"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 3. DETAILS PANE (The "Detail" part) -->
        <Border Grid.Column="2" BorderBrush="#DCDDE1" BorderThickness="1,0" Padding="20">
            <!-- This section only shows its content if a task is selected -->
            <Grid Visibility="{Binding SelectedTask, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Task Review" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Separator/>

                    <Label Content="Task Title:" Foreground="Gray" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedTask.Title}" FontSize="16" FontWeight="SemiBold"/>

                    <Label Content="Description:" Foreground="Gray" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SelectedTask.Description}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <Label Content="Reward Points:" Foreground="Gray"/>
                    <TextBlock Text="{Binding SelectedTask.Points}" FontWeight="Bold" Foreground="Green"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                        <Button Content="Approve" Command="{Binding ApproveCommand}" 
                                Width="100" Height="35" Background="#27AE60" Foreground="White" Margin="0,0,10,0"/>
                        <Button Content="Reject" Command="{Binding RejectCommand}" 
                                Width="100" Height="35" Background="#C0392B" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4. RIGHT SIDEBAR: Leaderboard (Top 5) -->
        <Border Grid.Column="3" Background="#ECF0F1" Padding="10">
            <StackPanel>
                <TextBlock Text="Top Performers" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding TopUsers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="5" Margin="0,2" Padding="8">
                                <DockPanel>
                                    <TextBlock Text="{Binding Username}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding TotalPoints}" DockPanel.Dock="Right" TextAlignment="Right" Foreground="#2980B9" FontWeight="Bold"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
        
        <!-- User Popup -->
        <Grid x:Name="UserOverlay" Grid.ColumnSpan="4" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="Black" Opacity="0.6"/>
            <local:CreateUserView x:Name="CreateUserPopup" 
                               Grid.Row="0"
                               Width="400"
                               Height="350"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center"/>
        </Grid>
        <!--Task Popup-->
        <Grid x:Name="TaskOverlay" Grid.ColumnSpan="4" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="Black" Opacity="0.6"/>
            <local:CreateTaskView x:Name="CreateTaskPopup"
                Grid.Row="0"
                Width="400"
                Height="350"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"/>
        </Grid>
       
    </Grid>
</Window>