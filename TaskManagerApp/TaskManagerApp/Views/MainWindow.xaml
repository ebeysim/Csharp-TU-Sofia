<Window x:Class="TaskManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TaskManagerApp.Views"
        Title="Task Manager" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Simple header -->
        <TextBlock Text="Task Manager" FontSize="18" FontWeight="Bold" Margin="10" />

        <!-- Placeholder for views; in a real app you'd use a navigation/content control -->
        <ContentControl Grid.Row="1" x:Name="MainContent" />
    </Grid>
</Window>