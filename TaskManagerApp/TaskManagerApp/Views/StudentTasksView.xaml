<Window x:Class="TaskManagerApp.Views.StudentTasksView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:TaskManagerApp.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Student Tasks" Height="600" Width="800">
    <Window.Resources>
        <converters:PriorityToColorConverter x:Key="PriorityToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Background="#F5F6FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,0,1,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Name="Title" Foreground="#2C3E50" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Border Background="#E8F6EF" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Total Points: " VerticalAlignment="Center" Foreground="#27AE60"/>
                            <TextBlock Text="{Binding TotalPoints}" 
                                   FontSize="18" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Row="3" Content="Logout" 
                        Click = "Logout_Click"
                        Background="#E74C3C" Foreground="White" 
                        Height="35" FontWeight="SemiBold" Margin="0,10,0,0">
                    </Button>
                </StackPanel>

                <Separator Grid.Row="1" Margin="0,5,0,15"/>

                <DockPanel Grid.Row="2">
                    <TextBlock Text="Your Tasks" DockPanel.Dock="Top" 
                           FontSize="14" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                    <ListView ItemsSource="{Binding MyTasks}" 
                        SelectedItem="{Binding SelectedTask}"
                        BorderThickness="0" Margin="5">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding TaskModel.Title}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding TaskModel.Priority}" Foreground="{Binding TaskModel.Priority, Converter={StaticResource PriorityToColorConverter}}" FontSize="10" FontStyle="Italic"/>
                                    <TextBlock Text="{Binding IsComplete, StringFormat='Completed: {0}'}" FontSize="10" FontStyle="Italic"/>
                                    <TextBlock Text="{Binding TaskModel.PointValue, StringFormat='Points: {0}'}" FontSize="10" FontStyle="Italic"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" BorderBrush="#DCDDE1" BorderThickness="1,0" Padding="20">
            <!-- This section only shows its content if a task is selected -->
            <Grid DataContext ="{Binding SelectedTask}"  Visibility="{Binding SelectedTask, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Task Review" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Separator/>

                    <Label Content="Task Title:" Foreground="Gray" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding TaskModel.Title}" FontSize="16" FontWeight="SemiBold"/>

                    <Label Content="Description:" Foreground="Gray" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding TaskModel.Description}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <Label Content="Assigned Date:" Foreground="Gray" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding AssignedDate}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <Label Content="Status:" Foreground="Gray" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding IsCompleted}" TextWrapping="Wrap" Margin="0,0,0,20"/>


                    <Button Content="Complete Task" 
                        Click="CompleteTask_Click"
                        Width="200" Height="50" HorizontalAlignment="Left" Margin="0,50,0,0"
                        Background="#27AE60" Foreground="White" FontSize="16" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="25"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
