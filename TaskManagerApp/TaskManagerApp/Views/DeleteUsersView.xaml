<UserControl x:Class="TaskManagerApp.Views.DeleteUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Width="320" d:DesignHeight="400">

    <Border Background="White" 
            BorderBrush="#DCDDE1" 
            BorderThickness="1" 
            CornerRadius="12" 
            Padding="15">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,6">
                <TextBlock Text="Delete Students" 
                           FontSize="20" 
                           HorizontalAlignment="Center"
                           FontWeight="Bold" 
                           Foreground="#2D3436"/>
                <TextBlock Text="Select users to remove" 
                           FontSize="13" 
                           HorizontalAlignment="Center"
                           Foreground="Gray"/>
            </StackPanel>

            <ListBox Grid.Row="1" 
         ItemsSource="{Binding AllStudents}" 
         SelectionMode="Multiple"
         x:Name="UsersDeleteList"
         MaxHeight="180"
         BorderThickness="0"
         Background="Transparent"
         HorizontalContentAlignment="Stretch">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#F1F2F6" 
                    BorderThickness="0,0,0,1" 
                    Padding="4,6"
                    HorizontalAlignment="Stretch">

                            <DockPanel LastChildFill="True">
                                <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" 
                              DockPanel.Dock="Left"
                              VerticalAlignment="Center" 
                              Margin="0,0,10,0"/>

                                <TextBlock Text="{Binding TotalPoints, StringFormat={}{0} pts}"
                               DockPanel.Dock="Right"
                               FontSize="12"
                               Foreground="#2980B9"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextAlignment="Right"
                               Margin="0,0,12,0"/>

                                <TextBlock Text="{Binding Username}" 
                               FontSize="13" 
                               Foreground="#2D3436"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                <Button Content="Confirm Delete"
                        x:Name="DeleteButton"
                        Click="DeleteSelected_Click"
                        Height="34" 
                        Background="#E74C3C" 
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Margin="0,0,0,8">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Cancel" 
                        Click="Cancel_Click"
                        Height="30" 
                        Background="Transparent" 
                        Foreground="#636E72"
                        BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>